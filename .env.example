EXPO_PUBLIC_API_URL=https://api.example.com

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Token da API Cosmos (Bluesoft) usada no scanner de código de barras.
# Obtenha em https://cosmos.bluesoft.com.br
# IMPORTANTE: variáveis EXPO_PUBLIC_* ficam embutidas no bundle e são
# visíveis no app extraído. Para produção, mover esta integração para um
# backend próprio que armazene o token no servidor.
EXPO_PUBLIC_COSMOS_TOKEN=
